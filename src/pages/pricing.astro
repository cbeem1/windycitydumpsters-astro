---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    q: "Are there extra charges for heavy materials?",
    a: "Concrete, dirt, brick, and asphalt are considered heavy materials and may have different pricing. Just let us know what you're disposing of when you call.",
  },
  {
    q: "What if I need the dumpster longer than 7 days?",
    a: "Extended rental periods are available at a daily rate. Let us know upfront and we'll include it in your quote.",
  },
  {
    q: "Do I need a permit?",
    a: "If you're placing the dumpster on a public street or alley in Chicago, a city permit may be required. We can advise you on this when you call — it's an easy process.",
  },
];
---

<BaseLayout
  title="Dumpster Rental Pricing Chicago | Free Quote | Windy City Dumpsters"
  description="Get a free dumpster rental quote in under 2 minutes. Call (224) 725-3311 or fill out the form. No hidden fees, same-day delivery available."
  canonicalURL="https://windycitydumpsters.com/pricing"
>

  <!-- Page Hero -->
  <section class="bg-navy text-white py-14 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4">Dumpster Rental Pricing</h1>
      <p class="text-white/80 text-lg">
        Every job is different. Get a free quote in under 2 minutes — call (224) 725-3311 or fill out the form below.
      </p>
    </div>
  </section>

  <!-- Quote Form -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="bg-red px-6 py-4">
          <p class="text-white font-bold text-center text-lg">Get a Free Quote — Takes 60 Seconds</p>
        </div>
        <iframe src="https://tally.so/r/wMZkJo?transparentBackground=1" width="100%" height="500" frameborder="0" title="Free dumpster rental quote form"></iframe>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="bg-gray-50 border-y border-gray-200 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-extrabold text-navy text-center mb-10">What's Always Included</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          "Flat-rate quote — no hidden charges",
          "Delivery and pickup",
          "Standard 7-day rental period",
          "Proper, licensed disposal",
          "Same-day delivery when available",
          "Friendly, professional service",
        ].map((item) => (
          <div class="flex items-center gap-3 bg-white rounded-lg p-4 border border-gray-200 shadow-sm">
            <span class="text-red font-bold text-lg">✓</span>
            <span class="text-gray-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-extrabold text-navy text-center mb-10">Pricing FAQs</h2>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <h3 class="font-bold text-navy mb-2">{faq.q}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Get a Free Quote CTA -->
  <section class="py-16 px-4 bg-navy text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to Book? Get a Free Quote.</h2>
      <p class="text-white/80 mb-8 text-lg">Call us or fill out the form — we'll get back to you within 1 hour.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+12247253311"
          class="inline-flex items-center justify-center gap-2 bg-red text-white font-bold px-8 py-4 rounded-xl hover:bg-red/90 transition-colors text-lg shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
          </svg>
          Call (224) 725-3311
        </a>
        <a
          href="https://tally.so/r/wMZkJo" target="_blank" rel="noopener"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 border-2 border-white text-white font-bold px-8 py-4 rounded-xl hover:bg-white hover:text-navy transition-colors text-lg"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
