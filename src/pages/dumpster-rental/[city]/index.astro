---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import cities from '../../../data/cities.json';
import sizes from '../../../data/sizes.json';

export async function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { cityData: city },
  }));
}

const { cityData } = Astro.props;
const {
  city,
  stateAbbr,
  county,
  slug,
  phone,
  serviceArea,
  permitInfo,
  transferStation,
  commonUses,
  localNote,
  tallyFormUrl,
} = cityData;

const phoneHref = `tel:+1${phone.replace(/\D/g, '')}`;
const availableSizes = sizes.filter((s) => s.available);

// Other cities for internal linking
const otherCities = cities.filter((c) => c.slug !== slug);

const pageTitle = `Dumpster Rental in ${city}, ${stateAbbr} | Windy City Dumpsters`;
const pageDescription = `Rent a dumpster in ${city}, ${stateAbbr} from Windy City Dumpsters. Same-day delivery, permit help, and no hidden fees. Call ${phone}.`;
const canonicalURL = `https://windycitydumpsters.com/dumpster-rental/${slug}/`;

// Extract a short permit sentence for the Quick Answer block
// We take up to the first two sentences of permitInfo to keep it concise
function getPermitSummary(info: string): string {
  const sentences = info.match(/[^.!?]+[.!?]+/g) || [];
  return sentences.slice(0, 2).join(' ').trim();
}
const permitSummary = getPermitSummary(permitInfo);

// Build FAQ data — conversational, AI-chatbot-style questions
type FAQ = { q: string; a: string };
const faqs: FAQ[] = [
  {
    q: `How much does it cost to rent a dumpster in ${city}?`,
    a: `Dumpster rental pricing in ${city} depends on the container size (10, 20, or 30 yard), your rental duration, and the type of debris you're disposing of. We provide flat-rate quotes that include delivery, pickup, and disposal — no surprise fees. Call us at ${phone} for a free quote; most quotes take under 2 minutes.`,
  },
  {
    q: `Do I need a permit for a dumpster in ${city}?`,
    a: permitInfo,
  },
  {
    q: `What size dumpster do I need?`,
    a: `We offer three sizes in ${city}: the 10-yard dumpster (best for single-room cleanouts and heavy debris like concrete), the 20-yard dumpster (our most popular size, ideal for kitchen/bathroom remodels and large garage cleanouts), and the 30-yard dumpster (for whole-house gut rehabs, large roofing tear-offs, and commercial projects). Common uses in ${city} include ${commonUses.slice(0, 3).join(', ')}. Not sure? Call us and we'll help you pick the right size.`,
  },
  {
    q: `How fast can I get a dumpster in ${city}?`,
    a: `Same-day delivery is available in ${city} — call us at ${phone} before noon and we can typically have a dumpster at your location the same day. Next-day delivery is available for bookings placed later in the day. We serve ${city} and surrounding ${county} County communities.`,
  },
  {
    q: `What can I put in the dumpster?`,
    a: `You can fill our dumpsters with most household and construction debris — including furniture, appliances, drywall, lumber, roofing shingles, flooring, yard waste, and general junk. Common loads in ${city} include ${commonUses.slice(0, 3).join(', ')}. Prohibited items include hazardous waste (paint, solvents, chemicals), electronics (e-waste), tires, batteries, and asbestos-containing materials. Call us if you're unsure about a specific item.`,
  },
  ...(slug === 'chicago-il'
    ? [
        {
          q: 'Do I need a permit to place a dumpster on a Chicago street?',
          a: `Yes. Any dumpster placed on a public street or sidewalk in Chicago requires a permit from the Chicago Department of Transportation (CDOT) through the City's Inspection, Permitting &amp; Licensing portal. Permits require proof of liability insurance naming the City as additional insured, plus a letter of credit. We handle all of this on your behalf — just let us know it's a street placement when you book.`,
        },
        {
          q: 'Can I use an alley instead of the street for my Chicago dumpster?',
          a: `Yes, and we recommend it when possible. Chicago's dense neighborhoods have alleys behind most two-flats and greystones, and placing the dumpster in the alley typically eliminates the need for a CDOT street permit entirely. Just make sure the alley can fit the dumpster — 10-yard and 20-yard units are usually fine; 30-yard units may be tight.`,
        },
        {
          q: 'Why is my Chicago dumpster so heavy?',
          a: `Chicago's older building stock — greystones, two-flats, and brick six-flats built before 1940 — produces substantially heavier debris than modern construction. Old plaster lath, masonry, and original brick weigh 3–4× more than drywall and wood framing. Interior gut jobs routinely exceed standard weight limits. We strongly recommend discussing your project type when booking so we can set an accurate weight allowance upfront.`,
        },
      ]
    : slug === 'naperville-il'
    ? [
        {
          q: 'Do I need a permit to place a dumpster on a Naperville street?',
          a: `Naperville requires a Right-of-Way (ROW) permit from the City's Public Works Department for any dumpster placed in a public right-of-way — street, alley, parkway, or sidewalk. The City requests up to 14 days for review. Most residential placements go on private driveways in Naperville, which avoids the permit requirement entirely. We handle ROW applications when street placement is needed.`,
        },
        {
          q: 'What is the most common reason people rent dumpsters in Naperville?',
          a: `Naperville's large suburban housing stock drives high demand for kitchen and bathroom remodel cleanouts, basement finishing debris removal, and deck tear-offs — especially in spring. We see a significant surge from March through June as homeowners start warm-weather renovation projects. New construction site cleanup is also common given Naperville's continued residential development.`,
        },
        {
          q: 'Does DuPage County have special disposal requirements I should know about?',
          a: `Yes. DuPage County requires certified disposal receipts for construction and demolition (C&D) debris — documentation that waste was delivered to a licensed facility. Reputable haulers like Windy City Dumpsters provide these receipts automatically as part of the rental. This is worth asking about if you're comparing quotes from multiple companies.`,
        },
      ]
    : [
        {
          q: `What are the permit rules for dumpster placement in ${city}?`,
          a: permitInfo,
        },
        {
          q: `What's the local dumpster rental experience like in ${city}?`,
          a: localNote,
        },
        {
          q: `Where does my debris go after pickup in ${city}?`,
          a: transferStation,
        },
      ]),
];

// JSON-LD schemas
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Windy City Dumpsters',
  telephone: phone,
  url: 'https://windycitydumpsters.com',
  image: 'https://windycitydumpsters.com/img/logo.svg',
  description: `Roll-off dumpster rental in ${city}, ${stateAbbr} — 10, 20, and 30 yard sizes with same-day delivery available across ${county} County.`,
  priceRange: '$$',
  areaServed: [
    { '@type': 'City', name: city },
    ...serviceArea
      .filter((area: string) => area !== city)
      .map((area: string) => ({ '@type': 'City', name: area })),
  ],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: [
      'Monday',
      'Tuesday',
      'Wednesday',
      'Thursday',
      'Friday',
      'Saturday',
      'Sunday',
    ],
    opens: '07:00',
    closes: '19:00',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: city,
    addressRegion: 'IL',
    addressCountry: 'US',
  },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Dumpster Rental',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Windy City Dumpsters',
    telephone: '(224) 725-3311',
  },
  areaServed: {
    '@type': 'City',
    name: `${city}, IL`,
  },
  description: `Roll-off dumpster rental in ${city}, IL — 10, 20, and 30 yard sizes with same-day delivery.`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://windycitydumpsters.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Dumpster Rental',
      item: 'https://windycitydumpsters.com/dumpster-rental/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: `Dumpster Rental in ${city}, ${stateAbbr}`,
      item: canonicalURL,
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalURL={canonicalURL} ogTitle={pageTitle} ogDescription={pageDescription}>

  <!-- JSON-LD Schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <!-- Breadcrumbs -->
  <nav class="bg-gray-100 py-2 px-4 text-sm text-gray-500" aria-label="Breadcrumb">
    <ol class="max-w-6xl mx-auto flex items-center gap-2">
      <li><a href="/" class="hover:text-red transition-colors">Home</a></li>
      <li class="text-gray-400">/</li>
      <li><a href="/dumpster-rental/" class="hover:text-red transition-colors">Dumpster Rental</a></li>
      <li class="text-gray-400">/</li>
      <li class="text-gray-700 font-medium" aria-current="page">{city}, {stateAbbr}</li>
    </ol>
  </nav>

  <!-- Hero + Above-the-Fold Lead Capture -->
  <section class="bg-navy text-white py-10 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

        <!-- Left: Headline + CTA -->
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 leading-tight">
            Dumpster Rental in {city}, {stateAbbr}
          </h1>
          <p class="text-white/85 text-lg mb-6">
            10, 20, and 30-yard roll-off dumpsters. Flat-rate pricing, same-day delivery, and permit help for street placements.
          </p>

          <!-- Click-to-Call -->
          <a
            href={phoneHref}
            class="inline-flex items-center gap-3 bg-red text-white font-bold px-6 py-4 rounded-xl text-2xl shadow-lg hover:bg-red/90 transition-colors mb-6 w-full sm:w-auto justify-center"
            aria-label={`Call Windy City Dumpsters at ${phone}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
            </svg>
            {phone}
          </a>

        </div>

        <!-- Right: Tally Form -->
        <div id="quote-form" class="bg-white rounded-xl overflow-hidden shadow-xl">
          <div class="bg-red px-4 py-3">
            <p class="text-white font-bold text-center">Get a Free Quote — Takes 60 Seconds</p>
          </div>
          <iframe
            src={`${tallyFormUrl}?transparentBackground=1`}
            width="100%"
            height="500"
            frameborder="0"
            title={`Dumpster rental quote form for ${city}, ${stateAbbr}`}
          ></iframe>
        </div>

      </div>
    </div>
  </section>

  <!-- Quick Answer Block -->
  <section class="py-6 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="border-2 border-navy rounded-xl bg-gray-50 p-6">
        <h2 class="text-sm font-bold text-navy uppercase tracking-widest mb-3">Quick Answer</h2>
        <p class="text-gray-800 leading-relaxed">
          Windy City Dumpsters provides 10, 20, and 30-yard roll-off dumpster rentals in {city}, {stateAbbr} with same-day delivery available across {county} County. {permitSummary} Call <a href={phoneHref} class="text-red font-semibold hover:underline">{phone}</a> or request a free quote online — most quotes take under 2 minutes.
        </p>
      </div>
    </div>
  </section>

  <!-- Size Options Grid -->
  <section class="py-12 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2 text-center">
        Dumpster Sizes Available in {city}
      </h2>
      <p class="text-center text-gray-600 mb-8">Click a size to see full specs, best uses, and weight limits.</p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {availableSizes.map((size) => (
            <a
              href={`/dumpster-rental/${slug}/${size.slug}/`}
              class={`group relative block bg-white border-2 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-200 ${size.popular ? 'border-red' : 'border-gray-200 hover:border-red'}`}
            >
              {size.popular && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-red text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                  Most Popular
                </span>
              )}

              <h3 class="text-xl font-bold text-navy mb-3">{size.name}</h3>

              <p class="text-sm text-gray-500 mb-1">{size.dimensions}</p>
              <p class="text-sm text-gray-500 mb-4">{size.holds}</p>

              <ul class="space-y-1 mb-4">
                {size.bestFor.slice(0, 3).map((use) => (
                  <li class="flex items-center gap-2 text-sm text-gray-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {use}
                  </li>
                ))}
              </ul>

              <div class="inline-flex items-center gap-1 text-sm font-semibold text-red group-hover:underline">
                View details &amp; book
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
        ))}
      </div>

      <p class="text-center mt-6 text-gray-600 text-sm">
        Not sure which size you need? <a href="/dumpster-sizes/" class="text-red font-semibold hover:underline">See our full size guide →</a>
      </p>
    </div>
  </section>

  <!-- Local Info Block (anti-thin-content) -->
  <section class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-8 text-center">
        Local Information for {city} Dumpster Rentals
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- Permit Info -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-amber-400 text-white rounded-full p-2 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-amber-900">Permit Requirements in {city}</h3>
          </div>
          <p class="text-amber-800 text-sm leading-relaxed">{permitInfo}</p>
        </div>

        <!-- Transfer Station -->
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-blue-600 text-white rounded-full p-2 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-blue-900">Transfer Stations &amp; Disposal</h3>
          </div>
          <p class="text-blue-800 text-sm leading-relaxed">{transferStation}</p>
        </div>

        <!-- Common Uses -->
        <div class="bg-green-50 border border-green-200 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-green-600 text-white rounded-full p-2 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-green-900">Common Uses in {city}</h3>
          </div>
          <ul class="space-y-2">
            {commonUses.map((use: string) => (
              <li class="flex items-center gap-2 text-sm text-green-800">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="capitalize">{use}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Local Note -->
        <div class="bg-navy text-white rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-red rounded-full p-2 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold">Local Insight: {city}</h3>
          </div>
          <p class="text-white/85 text-sm leading-relaxed">{localNote}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Service Area Tag Cloud -->
  <section class="py-10 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-xl font-bold text-navy mb-6">Areas We Serve Near {city}</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {serviceArea.map((area: string) => (
          <span class="bg-white border border-gray-200 text-gray-700 text-sm font-medium px-4 py-2 rounded-full shadow-sm">
            {area}
          </span>
        ))}
      </div>
      <p class="text-sm text-gray-500 mt-4">
        Don't see your exact neighborhood? Call us at <a href={phoneHref} class="text-red font-semibold hover:underline">{phone}</a> — we likely serve your area.
      </p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-8 text-center">
        Frequently Asked Questions — Dumpster Rental in {city}
      </h2>

      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details
            class="group bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm"
            open={i === 0}
          >
            <summary class="flex items-center justify-between cursor-pointer px-6 py-4 font-semibold text-navy hover:text-red transition-colors list-none">
              <span>{faq.q}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed border-t border-gray-100">
              <p class="pt-3">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="py-10 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-xl font-bold text-navy mb-6 text-center">Dumpster Rental in Nearby Cities</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {otherCities.map((c) => (
          <a
            href={`/dumpster-rental/${c.slug}/`}
            class="inline-flex items-center gap-2 bg-white border-2 border-gray-200 text-navy font-semibold px-5 py-3 rounded-xl hover:border-red hover:text-red transition-all text-sm shadow-sm"
          >
            Dumpster Rental in {c.city}, {c.stateAbbr}
          </a>
        ))}
        <a
          href="/dumpster-sizes/"
          class="inline-flex items-center gap-2 bg-white border-2 border-gray-200 text-navy font-semibold px-5 py-3 rounded-xl hover:border-red hover:text-red transition-all text-sm shadow-sm"
        >
          Full Dumpster Size Guide
        </a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-12 px-4 bg-navy text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to Book Your {city} Dumpster?</h2>
      <p class="text-white/80 mb-6 text-lg">Same-day delivery available. Flat-rate pricing. No hidden fees.</p>
      <a
        href={phoneHref}
        class="inline-flex items-center gap-3 bg-red text-white font-bold px-8 py-4 rounded-xl text-xl shadow-lg hover:bg-red/90 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
        </svg>
        {phone}
      </a>
    </div>
  </section>

</BaseLayout>
