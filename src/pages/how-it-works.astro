---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  {
    step: 1,
    title: "Call or Request a Quote",
    description: "Give us a call at (224) 725-3311 or fill out our quick quote form. Tell us your project type, location, and preferred delivery date. We'll recommend the right size and give you a flat-rate price — no surprises.",
    icon: "📞",
  },
  {
    step: 2,
    title: "We Deliver to Your Door",
    description: "Our driver arrives at your scheduled time and places the dumpster exactly where you need it — driveway, alley, or job site. Same-day delivery is available in most areas. No need to be home.",
    icon: "🚛",
  },
  {
    step: 3,
    title: "Fill It Up & We Haul It Away",
    description: "Load up your debris at your own pace — you keep the dumpster for your agreed rental period. When you're done, just give us a call and we'll pick it up and handle proper disposal for you.",
    icon: "♻️",
  },
];
---

<BaseLayout
  title="How Dumpster Rental Works | Windy City Dumpsters"
  description="Renting a dumpster is easy with Windy City Dumpsters. 3 simple steps: call for a quote, we deliver, you fill it up and we haul it away."
  canonicalURL="https://windycitydumpsters.com/how-it-works"
>

  <!-- Page Hero -->
  <section class="bg-navy text-white py-14 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4">How It Works</h1>
      <p class="text-white/80 text-lg">
        Renting a dumpster should be simple. Here's how we make it effortless from start to finish.
      </p>
    </div>
  </section>

  <!-- 3-Step Process -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col gap-12">
        {steps.map((step, index) => (
          <div class={`flex flex-col sm:flex-row gap-8 items-start ${index % 2 === 1 ? 'sm:flex-row-reverse' : ''}`}>
            <!-- Icon & Number -->
            <div class="flex-shrink-0 flex flex-col items-center">
              <div class="w-20 h-20 rounded-full bg-navy flex items-center justify-center text-4xl shadow-lg">
                {step.icon}
              </div>
              <div class="mt-2 bg-red text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center">
                {step.step}
              </div>
            </div>

            <!-- Content -->
            <div class="flex-1 bg-white rounded-2xl border border-gray-200 p-8 shadow-sm">
              <h2 class="text-xl sm:text-2xl font-extrabold text-navy mb-3">
                Step {step.step}: {step.title}
              </h2>
              <p class="text-gray-600 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Teaser -->
  <section class="bg-gray-50 border-t border-gray-200 py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl font-extrabold text-navy mb-4">It Really Is That Easy</h2>
      <p class="text-gray-600 mb-8">No hidden fees. No complicated contracts. Just fast, reliable dumpster service in Chicago and the suburbs.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+12247253311"
          class="inline-flex items-center justify-center gap-2 bg-red text-white font-bold px-8 py-4 rounded-xl hover:bg-red/90 transition-colors text-lg"
        >
          Call (224) 725-3311
        </a>
        <a
          href="/dumpster-sizes"
          class="inline-flex items-center justify-center gap-2 bg-navy text-white font-bold px-8 py-4 rounded-xl hover:bg-navy/90 transition-colors text-lg"
        >
          View Sizes
        </a>
      </div>
    </div>
  </section>

  <!-- Get a Free Quote CTA -->
  <section class="py-16 px-4 bg-navy text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to Book? Get a Free Quote.</h2>
      <p class="text-white/80 mb-8 text-lg">Call us or fill out the form — we'll get back to you within 1 hour.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+12247253311"
          class="inline-flex items-center justify-center gap-2 bg-red text-white font-bold px-8 py-4 rounded-xl hover:bg-red/90 transition-colors text-lg shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
          </svg>
          Call (224) 725-3311
        </a>
        <a
          href="https://tally.so/r/wMZkJo" target="_blank" rel="noopener"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 border-2 border-white text-white font-bold px-8 py-4 rounded-xl hover:bg-white hover:text-navy transition-colors text-lg"
        >
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
